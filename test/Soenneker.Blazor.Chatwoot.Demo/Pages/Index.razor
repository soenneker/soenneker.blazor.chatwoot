@page "/"
@using Soenneker.Blazor.Chatwoot.Configuration

<PageTitle>Soenneker.Blazor.Chatwoot demo</PageTitle>

<Div Space="Space.Y.Is4">
    <Paragraph TextSize="TextSize.Sm" Class="text-muted-foreground">
        Chatwoot widget demo. Set <code class="rounded bg-muted px-1 py-0.5 text-xs">WebsiteToken</code> in code when testing a live inbox.
    </Paragraph>

    <Chatwoot Configuration="_config" />
</Div>

@code {
    private readonly ChatwootConfiguration _config = new() { WebsiteToken = "" };
}
